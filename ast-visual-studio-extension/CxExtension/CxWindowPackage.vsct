<?xml version="1.0" encoding="utf-8"?>
<CommandTable xmlns="http://schemas.microsoft.com/VisualStudio/2005-10-18/CommandTable" xmlns:xs="http://www.w3.org/2001/XMLSchema">

	<Extern href="stdidcmd.h"/>

	<Extern href="vsshlids.h"/>

	<Commands package="guidCxWindowPackage">

		<Menus>
			<Menu guid="guidCxWindowPackageCmdSet" id="TWToolbar" type="ToolWindowToolbar">
				<CommandFlag>DefaultDocked</CommandFlag>
				<Strings>
					<ButtonText>Checkmarx extension toolbar</ButtonText>
					<CommandName>Checkmarx extension toolbar</CommandName>
				</Strings>
			</Menu>
			<Menu guid="guidCxWindowPackageCmdSet" id="CxAssistToolsMenu" type="Menu" priority="0x0600">
				<Parent guid="guidSHLMainMenu" id="IDM_VS_MENU_TOOLS"/>
				<Strings>
					<ButtonText>CxAssist</ButtonText>
					<CommandName>CxAssist</CommandName>
				</Strings>
			</Menu>
		</Menus>

		<Groups>
			<Group guid="guidCxWindowPackageCmdSet" id="MyMenuGroup" priority="0x0600">
				<Parent guid="guidSHLMainMenu" id="IDM_VS_MENU_TOOLS"/>
			</Group>
			<Group guid="guidCxWindowPackageCmdSet" id="CxAssistToolsGroup" priority="0x0100">
				<Parent guid="guidCxWindowPackageCmdSet" id="CxAssistToolsMenu"/>
				<Strings>
					<CommandName>CxAssist</CommandName>
				</Strings>
			</Group>
			<Group guid="guidCxWindowPackageCmdSet" id="TWToolbarGroup" priority="0x0000">
				<Parent guid="guidCxWindowPackageCmdSet" id="TWToolbar" />
			</Group>
			<!-- Error List context menu: place commands directly (no submenu); Visible/Enabled set in code when CxAssist finding selected -->
			<Group guid="guidCxAssistErrorListCmdSet" id="CxAssistErrorListGroup" priority="0x0300">
				<Parent guid="guidSHLMainMenu" id="IDM_VS_CTXT_ERRORLIST"/>
				<Strings>
					<CommandName>Checkmarx One Assist</CommandName>
				</Strings>
			</Group>
		</Groups>

		<Buttons>
			<Button guid="guidCxWindowPackageCmdSet" id="CxWindowCommandId" priority="0x0100" type="Button">
				<Parent guid="guidSHLMainMenu" id="IDG_VS_WNDO_OTRWNDWS1"/>
				<Icon guid="CxImages" id="cxlogo" />
				<Strings>
					<ButtonText>Checkmarx</ButtonText>
				</Strings>
			</Button>
			<!-- ShowFindingsWindowCommand - DISABLED: Command still works programmatically but not visible in menu -->
			<!--
			<Button guid="guidShowFindingsWindowCommandSet" id="ShowFindingsWindowCommandId" priority="0x0101" type="Button">
				<Parent guid="guidSHLMainMenu" id="IDG_VS_WNDO_OTRWNDWS1"/>
				<Icon guid="CxImages" id="cxlogo" />
				<Strings>
					<ButtonText>Checkmarx Findings</ButtonText>
				</Strings>
			</Button>
			-->
			<!-- Error List context menu: Fix, View details (visible when a CxAssist finding is selected) -->
			<Button guid="guidCxAssistErrorListCmdSet" id="CxAssistErrorListFixId" priority="0x0100" type="Button">
				<Parent guid="guidCxAssistErrorListCmdSet" id="CxAssistErrorListGroup"/>
				<Strings>
					<ButtonText>Fix with Checkmarx One Assist</ButtonText>
					<CommandName>Fix with Checkmarx One Assist</CommandName>
				</Strings>
			</Button>
			<Button guid="guidCxAssistErrorListCmdSet" id="CxAssistErrorListViewDetailsId" priority="0x0200" type="Button">
				<Parent guid="guidCxAssistErrorListCmdSet" id="CxAssistErrorListGroup"/>
				<Strings>
					<ButtonText>View details</ButtonText>
					<CommandName>View details</CommandName>
				</Strings>
			</Button>
			<Button guid="guidCxAssistErrorListCmdSet" id="CxAssistErrorListIgnoreThisId" priority="0x0300" type="Button">
				<Parent guid="guidCxAssistErrorListCmdSet" id="CxAssistErrorListGroup"/>
				<CommandFlag>TextChanges</CommandFlag>
				<Strings>
					<ButtonText>Ignore this vulnerability</ButtonText>
					<CommandName>Ignore this vulnerability</CommandName>
				</Strings>
			</Button>
			<Button guid="guidCxAssistErrorListCmdSet" id="CxAssistErrorListIgnoreAllId" priority="0x0400" type="Button">
				<Parent guid="guidCxAssistErrorListCmdSet" id="CxAssistErrorListGroup"/>
				<CommandFlag>DefaultInvisible</CommandFlag>
				<CommandFlag>DynamicVisibility</CommandFlag>
				<Strings>
					<ButtonText>Ignore all of this type</ButtonText>
					<CommandName>Ignore all of this type</CommandName>
				</Strings>
			</Button>
		</Buttons>

		<Bitmaps>
			<Bitmap guid="CxImages" href="Resources\cx_logo16.16.png" usedList="cxlogo" />
		</Bitmaps>
	</Commands>

	<Symbols>
		<GuidSymbol name="guidCxWindowPackage" value="{63d5f3b4-a254-4bef-974b-0733c306ed2c}" />

		<GuidSymbol name="guidCxWindowPackageCmdSet" value="{e46cd6d8-268d-4e77-9074-071e72a25f39}">
			<IDSymbol name="CxWindowCommandId" value="0x0100" />
