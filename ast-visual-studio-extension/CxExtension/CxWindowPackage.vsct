			<IDSymbol name="ShowFindingsWindowCommandId" value="0x0110" />
		</GuidSymbol>

		<!-- CxAssist Error List context menu: Group parented to IDM_VS_CTXT_ERRORLIST (vsshlids.h); commands visible when CxAssist finding selected -->
		<GuidSymbol name="guidCxAssistErrorListCmdSet" value="{b7e8b6e3-8e3e-4e3e-8e3e-8e3e8e3e8e40}">
			<IDSymbol name="CxAssistErrorListGroup" value="0x0201" />
			<IDSymbol name="CxAssistErrorListFixId" value="0x0210" />
