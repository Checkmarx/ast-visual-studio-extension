		<GuidSymbol name="CxImages" value="{cca5f138-eee9-4fc7-8f65-fce867b52e22}">
			<IDSymbol name="cxlogo" value="1" />
		</GuidSymbol>

		<!-- TestErrorListCustomizationCommand - POC for AST-133228, tool command only -->
