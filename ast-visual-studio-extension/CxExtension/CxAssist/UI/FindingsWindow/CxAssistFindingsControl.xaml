<UserControl x:Class="ast_visual_studio_extension.CxExtension.CxAssist.UI.FindingsWindow.CxAssistFindingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ast_visual_studio_extension.CxExtension.CxAssist.UI.FindingsWindow"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:vsfx="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="450" d:DesignWidth="800"
             Background="Transparent">

    <!-- Match Scan Results tab: background, vertical divider lines, severity filter icons (Critical/High/Medium/Low/Info, no Malicious), all filters enabled by default -->
    <UserControl.Resources>
        <!-- Bool to Visibility Converter -->
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>

        <!-- TreeViewItem Style with hover and selection effects -->
        <Style x:Key="TreeViewItemStyle" TargetType="TreeViewItem">
            <Setter Property="IsExpanded" Value="True"/>
            <Setter Property="Padding" Value="2,2"/>
            <EventSetter Event="MouseDoubleClick" Handler="TreeViewItem_MouseDoubleClick"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TreeViewItem">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>
                            <Border x:Name="Bd"
                                    Grid.Row="0"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Expander Toggle -->
                                    <ToggleButton x:Name="Expander"
                                                  Grid.Column="0"
                                                  IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                  ClickMode="Press"
                                                  Width="16" Height="16"
                                                  Background="Transparent"
                                                  BorderThickness="0">
                                        <ToggleButton.Style>
                                            <Style TargetType="ToggleButton">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <Border Background="Transparent" Width="16" Height="16">
                                                                <TextBlock x:Name="ExpanderText"
                                                                           Text="▶"
                                                                           FontSize="10"
                                                                           HorizontalAlignment="Center"
                                                                           VerticalAlignment="Center"
                                                                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="ExpanderText" Property="Text" Value="▼"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </ToggleButton.Style>
                                    </ToggleButton>
                                    <!-- Content -->
                                    <ContentPresenter x:Name="PART_Header"
                                                      Grid.Column="1"
                                                      ContentSource="Header"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                </Grid>
                            </Border>
                            <!-- Children -->
                            <ItemsPresenter x:Name="ItemsHost" Grid.Row="1" Margin="16,0,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <!-- Hide expander if no children -->
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <!-- Hover effect: grey in dark theme -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxMouseOverBackgroundGradientBrushKey}}"/>
                            </Trigger>
                            <!-- Selection effect -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarSelectedBrushKey}}"/>
                            </Trigger>
                            <!-- Collapsed state -->
                            <Trigger Property="IsExpanded" Value="False">
                                <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Filter Button Style: compact margin so toolbar height matches Scan Results -->
        <Style x:Key="FilterButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="2,3,2,3"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <!-- Hover: grey in dark theme (no blue) for all filters -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxMouseOverBackgroundGradientBrushKey}}"/>
                                <Setter TargetName="Border" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsfx:VsBrushes.ActiveBorderKey}}"/>
                            </Trigger>
                            <!-- Checked (selected): same border as Scan Results -->
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:EnvironmentColors.CommandBarSelectedBrushKey}}"/>
                                <Setter TargetName="Border" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsfx:VsBrushes.ActiveBorderKey}}"/>
                            </Trigger>
                            <!-- Checked + Hover: grey hover when filter is selected -->
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsChecked" Value="True"/>
                                    <Condition Property="IsMouseOver" Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Border" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxMouseOverBackgroundGradientBrushKey}}"/>
                                <Setter TargetName="Border" Property="BorderBrush"
                                        Value="{DynamicResource {x:Static vsfx:VsBrushes.ActiveBorderKey}}"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Toolbar action buttons (Expand All, Collapse All, Settings): grey hover for dark theme, no blue -->
        <Style x:Key="ToolbarActionButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Border" Background="Transparent" BorderThickness="0" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background"
                                        Value="{DynamicResource {x:Static vsui:EnvironmentColors.ComboBoxMouseOverBackgroundGradientBrushKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <!-- HR line below tab row: black -->
        <Border Grid.ColumnSpan="4" Height="1" VerticalAlignment="Top"
                Background="#000000"
                BorderThickness="0"/>
        <Grid Grid.Column="0" Grid.ColumnSpan="4" Margin="0,2,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

        <!-- Loading Indicator (Overlay) -->
        <Border Grid.Row="0" Grid.RowSpan="2"
                x:Name="LoadingOverlay"
                Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                Panel.ZIndex="1000">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="⏳" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                <TextBlock Text="Loading findings..." FontSize="14" FontWeight="Bold"
                           Foreground="White" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Top Toolbar: compact height, HR line below toolbar (black) -->
        <Border Grid.Row="0"
                Background="Transparent"
                BorderBrush="#000000"
                BorderThickness="0,0,0,1"
                Padding="4,2,4,2">
            <!-- Severity filter icons: Malicious, Critical, High, Medium, Low; same size/margin as Scan Results -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <!-- Malicious Filter Button -->
                <ToggleButton x:Name="MaliciousFilterButton"
                             Style="{StaticResource FilterButtonStyle}"
                             ToolTip="Malicious"
                             Click="SeverityFilter_Click"
                             Tag="Malicious"
                             IsChecked="True">
                    <Image x:Name="MaliciousFilterIcon" Width="22" Height="22" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>

                <!-- Critical Filter Button -->
                <ToggleButton x:Name="CriticalFilterButton"
                             Style="{StaticResource FilterButtonStyle}"
                             ToolTip="Critical"
                             Click="SeverityFilter_Click"
                             Tag="Critical"
                             IsChecked="True">
                    <Image x:Name="CriticalFilterIcon" Width="22" Height="22" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>

                <!-- High Filter Button -->
                <ToggleButton x:Name="HighFilterButton"
                             Style="{StaticResource FilterButtonStyle}"
                             ToolTip="High"
                             Click="SeverityFilter_Click"
                             Tag="High"
                             IsChecked="True">
                    <Image x:Name="HighFilterIcon" Width="22" Height="22" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>

                <!-- Medium Filter Button -->
                <ToggleButton x:Name="MediumFilterButton"
                             Style="{StaticResource FilterButtonStyle}"
                             ToolTip="Medium"
                             Click="SeverityFilter_Click"
                             Tag="Medium"
                             IsChecked="True">
                    <Image x:Name="MediumFilterIcon" Width="22" Height="22" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>

                <!-- Low Filter Button -->
                <ToggleButton x:Name="LowFilterButton"
                             Style="{StaticResource FilterButtonStyle}"
                             ToolTip="Low"
                             Click="SeverityFilter_Click"
                             Tag="Low"
                             IsChecked="True">
                    <Image x:Name="LowFilterIcon" Width="22" Height="22" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>

                <!-- Pipe separator between severity and Expand All -->
                <TextBlock Text="|" VerticalAlignment="Center" Margin="6,0" FontSize="18"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" Opacity="0.7"/>

                <!-- Expand All: same icon as JetBrains plugin (AllIcons.Actions.Expandall) -->
                <Button x:Name="ExpandAllButton"
                        Click="ExpandAll_Click"
                        ToolTip="Expand All"
                        Style="{StaticResource ToolbarActionButtonStyle}"
                        Width="28" Height="28" Margin="2,0"
                        Background="Transparent" BorderThickness="0"
                        Padding="0">
                    <Image x:Name="ExpandAllIcon" Width="20" Height="20"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <!-- Collapse All: same icon as JetBrains plugin (AllIcons.Actions.Collapseall) -->
                <Button x:Name="CollapseAllButton"
                        Click="CollapseAll_Click"
                        ToolTip="Collapse All"
                        Style="{StaticResource ToolbarActionButtonStyle}"
                        Width="28" Height="28" Margin="2,0"
                        Background="Transparent" BorderThickness="0"
                        Padding="0">
                    <Image x:Name="CollapseAllIcon" Width="20" Height="20"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </Button>

                <!-- Pipe separator between Collapse All and Settings -->
                <TextBlock Text="|" VerticalAlignment="Center" Margin="6,0" FontSize="18"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" Opacity="0.7"/>

                <!-- Settings Button -->
                <Button x:Name="SettingsButton"
                        Click="Settings_Click"
                        ToolTip="Settings"
                        Style="{StaticResource ToolbarActionButtonStyle}"
                        Width="24" Height="24" Margin="2,0"
                        Background="Transparent" BorderThickness="0">
                    <TextBlock Text="⚙" FontSize="14"
                               Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                </Button>
            </StackPanel>
        </Border>

        <!-- TreeView -->
        <TreeView Grid.Row="1" Name="FindingsTreeView"
                  ItemsSource="{Binding FileNodes}"
                  ItemContainerStyle="{StaticResource TreeViewItemStyle}"
                  BorderThickness="0"
                  Background="Transparent"
                  Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}">

            <!-- Context Menu (right-click on vulnerability) -->
            <TreeView.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Fix with CxOne Assist" Click="FixWithCxOneAssist_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🔧" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="View Details" Click="ViewDetails_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="ℹ" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Navigate to Code" Click="NavigateMenuItem_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="➡" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Ignore vuln" Click="Ignore_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🚫" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <MenuItem Header="Ignore all" Click="IgnoreAll_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="🚫" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                    <Separator/>
                    <MenuItem Header="Copy" Click="CopyMenuItem_Click">
                        <MenuItem.Icon>
                            <TextBlock Text="📋" FontSize="14"/>
                        </MenuItem.Icon>
                    </MenuItem>
                </ContextMenu>
            </TreeView.ContextMenu>

            <TreeView.Resources>
                <!-- File Node Template (JetBrains-style: expander + file icon + name + severity badges) -->
                <HierarchicalDataTemplate DataType="{x:Type local:FileNode}" ItemsSource="{Binding Vulnerabilities}">
                    <StackPanel Orientation="Horizontal" Margin="0,2" VerticalAlignment="Center">
                        <!-- File Icon (same size as severity icons in list) -->
                        <Image Source="{Binding FileIcon}" Width="18" Height="18" Margin="0,0,3,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <!-- File Name (primary text) -->
                        <TextBlock Text="{Binding FileName}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                        <!-- Severity Count Badges (shield + count, JetBrains-style) -->
                        <ItemsControl ItemsSource="{Binding SeverityCounts}" VerticalAlignment="Center">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0,0,6,0">
                                        <Image Source="{Binding Icon}" Width="14" Height="14" Margin="0,0,2,0"
                                               VerticalAlignment="Center"
                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                        <TextBlock Text="{Binding Count}" FontWeight="SemiBold" FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </HierarchicalDataTemplate>

                <!-- Vulnerability Node Template (JetBrains-style: icon, primary text bright, secondary text darker) -->
                <DataTemplate DataType="{x:Type local:VulnerabilityNode}">
                    <StackPanel Orientation="Horizontal" Margin="0,2" VerticalAlignment="Center">
                        <!-- Severity Icon (aligned with JetBrains size) -->
                        <Image Source="{Binding SeverityIcon}" Width="14" Height="14" Margin="0,0,3,0"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality"/>
                        <!-- Primary text: risk type + package (larger, prominent - match JetBrains) -->
                        <TextBlock Text="{Binding PrimaryDisplayText}" VerticalAlignment="Center" TextWrapping="NoWrap"
                                   FontSize="13"
                                   Margin="0,0,6,0"
                                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                        <!-- Secondary text: source + location (smaller, dimmer - match JetBrains) -->
                        <TextBlock Text="{Binding SecondaryDisplayText}" VerticalAlignment="Center" TextWrapping="NoWrap"
                                   FontSize="13"
                                   Opacity="0.5"
                                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                    </StackPanel>
                </DataTemplate>
            </TreeView.Resources>
        </TreeView>

        <!-- Empty State Message -->
        <Border Grid.Row="1"
                Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}"
                Background="Transparent">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="No vulnerabilities found" FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
            </StackPanel>
        </Border>

        </Grid>
    </Grid>
</UserControl>

