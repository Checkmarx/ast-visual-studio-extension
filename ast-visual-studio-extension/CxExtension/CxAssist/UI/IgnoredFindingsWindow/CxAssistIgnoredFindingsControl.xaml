<UserControl x:Class="ast_visual_studio_extension.CxExtension.CxAssist.UI.IgnoredFindingsWindow.CxAssistIgnoredFindingsControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vsui="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0"
             xmlns:vsfx="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
             mc:Ignorable="d"
             d:DesignHeight="300" d:DesignWidth="900">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <!-- Severity filter toggle buttons -->
        <Style x:Key="FilterButtonStyle" TargetType="ToggleButton">
            <Setter Property="Margin" Value="2,5,2,5"/>
            <Setter Property="Background" Value="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarGradientBeginKey}}"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="3"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Border"
                                Background="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarGradientBeginKey}}"
                                BorderBrush="Transparent"
                                BorderThickness="0"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Background"
                                        Value="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background"
                                        Value="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Hyperlink-style button for clickable file references -->
        <Style x:Key="FileLinkButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0,1"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <TextBlock x:Name="TB"
                                   Text="{TemplateBinding Content}"
                                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.PanelHyperlinkBrushKey}}"
                                   Padding="{TemplateBinding Padding}"/>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="TB" Property="TextDecorations" Value="Underline"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Revive image button — just renders the SVG, no WPF border drawn -->
        <Style x:Key="ReviveButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="Transparent" Opacity="0.85">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Opacity" Value="1"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource VsBrush.ToolWindowBackground}"
          TextElement.Foreground="{DynamicResource VsBrush.ToolWindowText}">
        <Border BorderBrush="{DynamicResource {x:Static vsfx:VsBrushes.ToolWindowBorderKey}}"
                BorderThickness="1,1,1,1">
        <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Toolbar: severity icons | vulnerability type | sort -->
        <Border Grid.Row="0"
                BorderBrush="{DynamicResource {x:Static vsfx:VsBrushes.ToolWindowBorderKey}}"
                BorderThickness="0,0,0,1"
                Padding="0">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Height="35">

                <!-- Severity filter icon buttons -->
                <ToggleButton x:Name="SeverityMaliciousButton" Style="{StaticResource FilterButtonStyle}"
                              ToolTip="Malicious" Click="Filter_Click" IsChecked="True">
                    <Image x:Name="MaliciousFilterIcon" Width="18" Height="18" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>
                <ToggleButton x:Name="SeverityCriticalButton" Style="{StaticResource FilterButtonStyle}"
                              ToolTip="Critical" Click="Filter_Click" IsChecked="True">
                    <Image x:Name="CriticalFilterIcon" Width="18" Height="18" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>
                <ToggleButton x:Name="SeverityHighButton" Style="{StaticResource FilterButtonStyle}"
                              ToolTip="High" Click="Filter_Click" IsChecked="True">
                    <Image x:Name="HighFilterIcon" Width="18" Height="18" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>
                <ToggleButton x:Name="SeverityMediumButton" Style="{StaticResource FilterButtonStyle}"
                              ToolTip="Medium" Click="Filter_Click" IsChecked="True">
                    <Image x:Name="MediumFilterIcon" Width="18" Height="18" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>
                <ToggleButton x:Name="SeverityLowButton" Style="{StaticResource FilterButtonStyle}"
                              ToolTip="Low" Click="Filter_Click" IsChecked="True">
                    <Image x:Name="LowFilterIcon" Width="18" Height="18" Stretch="Uniform"
                           RenderOptions.BitmapScalingMode="HighQuality"/>
                </ToggleButton>

                <!-- Separator -->
                <Border Width="1" Height="20" VerticalAlignment="Center" Margin="6,0"
                        Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" Opacity="0.6"/>

                <!-- Vulnerability Type filter -->
                <Menu Background="Transparent">
                    <MenuItem ToolTip="Vulnerability Type" Style="{DynamicResource DefaultMenuItemStyle}" Padding="0" Margin="2,5,2,5">
                        <MenuItem.Icon>
                            <Image x:Name="VulnTypeFilterIcon" Width="16" Height="16" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </MenuItem.Icon>
                        <MenuItem Style="{DynamicResource DefaultMenuItemStyle}" x:Name="VulnSAST"
                                  Header="SAST" IsCheckable="True" IsChecked="True" Click="VulnType_Click" Tag="ASCA"/>
                        <MenuItem Style="{DynamicResource DefaultMenuItemStyle}" x:Name="VulnSCA"
                                  Header="SCA" IsCheckable="True" IsChecked="True" Click="VulnType_Click" Tag="OSS"/>
                        <MenuItem Style="{DynamicResource DefaultMenuItemStyle}" x:Name="VulnSecrets"
                                  Header="Secrets" IsCheckable="True" IsChecked="True" Click="VulnType_Click" Tag="Secrets"/>
                        <MenuItem Style="{DynamicResource DefaultMenuItemStyle}" x:Name="VulnIaC"
                                  Header="IaC" IsCheckable="True" IsChecked="True" Click="VulnType_Click" Tag="IaC"/>
                        <MenuItem Style="{DynamicResource DefaultMenuItemStyle}" x:Name="VulnContainers"
                                  Header="Containers" IsCheckable="True" IsChecked="True" Click="VulnType_Click" Tag="Containers"/>
                    </MenuItem>
                </Menu>

                <!-- Separator -->
                <Border Width="1" Height="20" VerticalAlignment="Center" Margin="6,0"
                        Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}" Opacity="0.6"/>

                <!-- Sort By -->
                <Menu Background="Transparent">
                    <MenuItem ToolTip="Sort By" Style="{DynamicResource DefaultMenuItemStyle}" Padding="0" Margin="2,5,2,5">
                        <MenuItem.Icon>
                            <Image x:Name="SortIconImage" Width="16" Height="16" Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </MenuItem.Icon>
                        <MenuItem Style="{DynamicResource DefaultMenuItemStyle}" x:Name="SortSevHighLow"
                                  Header="Severity (high → low)" IsCheckable="True" IsChecked="True" Click="SortBy_MenuClick" Tag="0"/>
                        <MenuItem Style="{DynamicResource DefaultMenuItemStyle}" x:Name="SortSevLowHigh"
                                  Header="Severity (low → high)" IsCheckable="True" Click="SortBy_MenuClick" Tag="1"/>
                        <Separator/>
                        <MenuItem Style="{DynamicResource DefaultMenuItemStyle}" x:Name="SortDateNew"
                                  Header="Date added (newest first)" IsCheckable="True" Click="SortBy_MenuClick" Tag="2"/>
                        <MenuItem Style="{DynamicResource DefaultMenuItemStyle}" x:Name="SortDateOld"
                                  Header="Date added (oldest first)" IsCheckable="True" Click="SortBy_MenuClick" Tag="3"/>
                    </MenuItem>
                </Menu>
            </StackPanel>
        </Grid>
        </Border>

        <!-- Undo notification bar (shown briefly after revive) -->
        <!-- Selection action bar — JetBrains layout:
             LEFT:  "N Risks selected  |  × Clear Selections"
             RIGHT: [↩ Revive Selected] outlined button -->
        <Border x:Name="SelectionBar" Grid.Row="2" Visibility="Collapsed"
                Background="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarOptionsBackgroundKey}}"
                BorderBrush="{DynamicResource {x:Static vsfx:VsBrushes.ToolWindowBorderKey}}"
                BorderThickness="0,0,0,1" Padding="12,6">
            <DockPanel>
                <!-- Revive Selected: filled+outlined button on the far right -->
                <Button DockPanel.Dock="Right" Click="ReviveSelected_Click"
                        Cursor="Hand" Margin="0,0,4,0"
                        OverridesDefaultStyle="True"
                        Focusable="False">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="ReviveSelBorder"
                                    CornerRadius="4"
                                    BorderThickness="1.5"
                                    BorderBrush="{DynamicResource {x:Static vsfx:VsBrushes.ToolWindowBorderKey}}"
                                    Background="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarGradientBeginKey}}"
                                    Padding="12,5">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#x21A9;" FontFamily="Segoe UI Symbol" FontSize="12"
                                               VerticalAlignment="Center" Margin="0,0,5,0"
                                               Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                    <TextBlock Text="Revive Selected" FontSize="12" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ReviveSelBorder" Property="Background"
                                            Value="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                                    <Setter TargetName="ReviveSelBorder" Property="BorderBrush"
                                            Value="{DynamicResource {x:Static vsfx:VsBrushes.ToolWindowBorderKey}}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Left side: count | separator | × Clear Selections -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock x:Name="SelectionBarText" Text="0 Risks selected"
                               FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"
                               Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                    <!-- Vertical separator -->
                    <Border Width="1" Height="16" Margin="12,0"
                            Background="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                            Opacity="0.4" VerticalAlignment="Center"/>
                    <!-- Clear Selections: bordered button matching Revive style -->
                    <Button Click="ClearSelection_Click" Cursor="Hand"
                            OverridesDefaultStyle="True" Focusable="False">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="ClearBorder"
                                        CornerRadius="4"
                                        BorderThickness="1.5"
                                        BorderBrush="{DynamicResource {x:Static vsfx:VsBrushes.ToolWindowBorderKey}}"
                                        Background="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarGradientBeginKey}}"
                                        Padding="12,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✕" FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"
                                                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                        <TextBlock Text="Clear Selections" FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="ClearBorder" Property="Background"
                                                Value="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                                        <Setter TargetName="ClearBorder" Property="BorderBrush"
                                                Value="{DynamicResource {x:Static vsfx:VsBrushes.ToolWindowBorderKey}}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Column header row -->
        <Grid x:Name="ColumnHeaderRow" Grid.Row="3" Margin="0,8,0,0" Visibility="Collapsed">
        <Border Padding="8,6" Background="Transparent">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="50"/>   <!-- checkbox -->
                    <ColumnDefinition Width="*"/>    <!-- Risk -->
                    <ColumnDefinition Width="140"/>  <!-- Last Updated -->
                    <ColumnDefinition Width="180"/>  <!-- Revive spacer -->
                </Grid.ColumnDefinitions>
                <CheckBox x:Name="SelectAllCheckBox" Grid.Column="0" Click="SelectAll_Click" ToolTip="Select all"
                          Focusable="False" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="Risk"
                           FontSize="14" FontWeight="Bold"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                           VerticalAlignment="Center" Opacity="0.7"/>
                <TextBlock Grid.Column="2" Text="Last Updated"
                           FontSize="14" FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                           VerticalAlignment="Center" Opacity="0.7"/>
            </Grid>
        </Border>
        </Grid>

        <!-- Findings list + empty state -->
        <Grid Grid.Row="4">
            <ListView x:Name="IgnoredList" SelectionMode="Extended"
                      Background="{DynamicResource VsBrush.ToolWindowBackground}"
                      Foreground="{DynamicResource VsBrush.ToolWindowText}"
                      BorderBrush="Transparent" BorderThickness="0"
                      ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListViewItem">
                                    <Grid x:Name="ItemRoot" Background="Transparent">
                                        <ContentPresenter/>
                                    </Grid>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemRoot" Property="Background"
                                                    Value="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="ItemRoot" Property="Background"
                                                    Value="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarMouseOverBackgroundGradientKey}}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <!-- Row layout: checkbox(50) | risk-content(*) | last-updated(140) | revive(180)
                             Matches JetBrains CHECKBOX_COL_WIDTH=50, Last Updated 120-160, Revive 180. -->
                        <Grid Margin="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="50"/>   <!-- checkbox -->
                                <ColumnDefinition Width="*"/>    <!-- risk content (card icon inside) -->
                                <ColumnDefinition Width="140"/>  <!-- last updated -->
                                <ColumnDefinition Width="180"/>  <!-- revive -->
                            </Grid.ColumnDefinitions>

                            <!-- Checkbox — vertically centred -->
                            <CheckBox Grid.Column="0"
                                      IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>

                            <!-- Risk content: card icon (44px) on top line alongside severity + title.
                                 Mirrors JetBrains buildRiskContent(): topLine FlowLayout LEFT with
                                 card icon + severity icon + bold name, then desc, then bottom chips. -->
                            <Grid Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,8,8,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>  <!-- top line: card icon + severity + title -->
                                    <RowDefinition Height="Auto"/>  <!-- description (up to 2 lines) -->
                                    <RowDefinition Height="Auto"/>  <!-- bottom chips -->
                                </Grid.RowDefinitions>

                                <!-- Top line: card icon (44px) + severity icon (16px) + title (includes severity) -->
                                <DockPanel Grid.Row="0" LastChildFill="True" Height="50">
                                    <Image DockPanel.Dock="Left"
                                           Source="{Binding CardIcon}"
                                           Width="44" Height="44"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <Image DockPanel.Dock="Left"
                                           Source="{Binding SeverityIcon}"
                                           Width="16" Height="16"
                                           Margin="0,0,4,0"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <TextBlock Text="{Binding Title}"
                                               FontWeight="Bold"
                                               FontSize="13"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                </DockPanel>

                                <!-- Description: dimmed by default, full opacity on row hover -->
                                <TextBlock Grid.Row="1"
                                           Text="{Binding DescriptionDisplay}"
                                           ToolTip="{Binding Entry.Description}"
                                           FontSize="13"
                                           FontWeight="Bold"
                                           TextWrapping="Wrap"
                                           TextTrimming="CharacterEllipsis"
                                           MaxHeight="36"
                                           Margin="0,2,0,4"
                                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Opacity" Value="0.6"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=ListViewItem}}" Value="True">
                                                    <Setter Property="Opacity" Value="1"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                                <!-- Bottom chips: engine chip SVG + file pill buttons -->
                                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,2,0,8">
                                    <!-- Engine chip: pre-built SVG (40×22), fully baked border+text -->
                                    <Image Source="{Binding ScannerChipIcon}"
                                           Height="22"
                                           Margin="0,0,6,0"
                                           VerticalAlignment="Center"
                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                    <!-- File pill buttons -->
                                    <ItemsControl ItemsSource="{Binding VisibleFileRefs}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Margin="0,0,6,0" Padding="0"
                                                        Background="Transparent" BorderThickness="0"
                                                        Focusable="False" IsTabStop="False"
                                                        OverridesDefaultStyle="True"
                                                        Cursor="Hand" Click="FileRef_Click"
                                                        Tag="{Binding}" ToolTip="{Binding AbsolutePath}">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="FilePill"
                                                                    Height="22"
                                                                    CornerRadius="11"
                                                                    BorderThickness="1.5"
                                                                    BorderBrush="{DynamicResource {x:Static vsfx:VsBrushes.ToolWindowBorderKey}}"
                                                                    Padding="8,0"
                                                                    Background="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarGradientBeginKey}}">
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <Image Source="{Binding DataContext.FileIcon, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                           Width="12" Height="12"
                                                                           Margin="0,0,4,0"
                                                                           VerticalAlignment="Center"/>
                                                                    <TextBlock Text="{Binding DisplayText}"
                                                                               FontSize="11"
                                                                               VerticalAlignment="Center"
                                                                               Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                                                </StackPanel>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                    <!-- Expand / collapse links -->
                                    <Button Content="{Binding ExpandLabel}"
                                            Style="{StaticResource FileLinkButtonStyle}"
                                            Click="ExpandFiles_Click" Tag="{Binding}"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding HasHiddenFiles, Converter={StaticResource BoolToVis}}"/>
                                    <Button Content="See less"
                                            Style="{StaticResource FileLinkButtonStyle}"
                                            Click="CollapseFiles_Click" Tag="{Binding}"
                                            Visibility="{Binding CanCollapse, Converter={StaticResource BoolToVis}}"/>
                                </StackPanel>
                            </Grid>

                            <!-- Last Updated — centred, same size as description, bold -->
                            <TextBlock Grid.Column="2"
                                       Text="{Binding DateAddedDisplay}"
                                       FontSize="13"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Center"
                                       Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>

                            <!-- Revive: pre-built SVG (90×28) baked into a clickable button -->
                            <Button Grid.Column="3"
                                    OverridesDefaultStyle="True"
                                    Focusable="False"
                                    Click="RowRevive_Click" Tag="{Binding}"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Center"
                                    Cursor="Hand"
                                    ToolTip="Revive this finding">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="ReviveBorder"
                                                CornerRadius="4"
                                                BorderThickness="1.5"
                                                BorderBrush="{DynamicResource {x:Static vsfx:VsBrushes.ToolWindowBorderKey}}"
                                                Background="{DynamicResource {x:Static vsfx:VsBrushes.CommandBarGradientBeginKey}}"
                                                Padding="8,4">
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="&#x21A9;" FontFamily="Segoe UI Symbol" FontSize="12"
                                                           VerticalAlignment="Center" Margin="0,0,5,0"
                                                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                                <TextBlock Text="Revive" FontSize="12" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"/>
                                            </StackPanel>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty state overlay -->
            <TextBlock x:Name="EmptyStateText" Text="No ignored findings"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       Foreground="{DynamicResource {x:Static vsui:EnvironmentColors.ToolWindowTextBrushKey}}"
                       FontSize="16" FontWeight="Bold"
                       Visibility="Collapsed"/>
        </Grid>

        </Grid>
        </Border>
    </Grid>
</UserControl>
