<Border x:Name="RootBorder"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        MaxWidth="500"
        Background="#2D2D30"
        BorderBrush="#3F3F46"
        BorderThickness="1"
        CornerRadius="4"
        Padding="12">
    <Border.Effect>
            <DropShadowEffect Color="Black" Opacity="0.3" BlurRadius="8" ShadowDepth="2"/>
        </Border.Effect>
        
        <StackPanel>
            <!-- JetBrains-style header: Checkmarx One Assist logo (image, not text) + ellipsis -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Image x:Name="HeaderLogoImage"
                       Grid.Column="0"
                       Height="20" Stretch="Uniform"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <Button x:Name="MoreOptionsButton" Grid.Column="2"
                        Content="︙" FontSize="14" Padding="4,0"
                        Background="Transparent" BorderThickness="0"
                        VerticalAlignment="Center"
                        ToolTip="More actions..."
                        Cursor="Hand"/>
            </Grid>

            <!-- Main vulnerability line: large severity icon + "Package@Version - Title" (JetBrains-style) -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Image x:Name="SeverityIcon"
                       Grid.Column="0"
                       Width="28" Height="28"
                       Margin="0,0,10,0"
                       VerticalAlignment="Center"
                       RenderOptions.BitmapScalingMode="HighQuality"/>
                <TextBlock x:Name="TitleText"
                           Grid.Column="1"
                           FontWeight="SemiBold"
                           FontSize="13"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Foreground="#DCDCDC"/>
            </Grid>
            <!-- Scanner badge (optional, below title when used) -->
            <Border x:Name="ScannerBadge"
                    CornerRadius="3" Padding="6,2"
                    Margin="0,0,0,8" HorizontalAlignment="Left"
                    Visibility="Collapsed">
                <TextBlock x:Name="ScannerText"
                           FontSize="10" FontWeight="SemiBold"
                           Foreground="White"/>
            </Border>
            
            <!-- Severity counts when multiple findings on same line (JetBrains-style) -->
            <StackPanel x:Name="SeverityCountPanel" Orientation="Horizontal" Margin="0,0,0,8" Visibility="Collapsed"/>
            
            <!-- Separator -->
            <Border x:Name="SeparatorLine1" Height="1" 
                    Background="#3F3F46"
                    Margin="0,0,0,8"/>
            
            <!-- Description -->
            <TextBlock x:Name="DescriptionText"
                       TextWrapping="Wrap"
                       FontSize="12"
                       Margin="0,0,0,8"
                       Foreground="#DCDCDC"/>
            
            <!-- Package Information (for SCA/OSS) -->
            <StackPanel x:Name="PackageInfoPanel" Visibility="Collapsed" Margin="0,0,0,8">
                <TextBlock FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#DCDCDC"
                           Margin="0,0,0,4">
                    Package:
                </TextBlock>
                <TextBlock x:Name="PackageNameText"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#DCDCDC"
                           Margin="0,0,0,2"/>

                <!-- CVE Information -->
                <TextBlock x:Name="CveText"
                           FontSize="11"
                           Foreground="#DCDCDC"
                           Margin="0,4,0,2"
                           Visibility="Collapsed"/>

                <!-- CVSS Score -->
                <TextBlock x:Name="CvssScoreText"
                           FontSize="11"
                           Foreground="#DCDCDC"
                           Margin="0,2,0,2"
                           Visibility="Collapsed"/>

                <!-- Recommended Version -->
                <StackPanel x:Name="RecommendedVersionPanel" Orientation="Horizontal" Margin="0,4,0,0" Visibility="Collapsed">
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="#DCDCDC">
                        Recommended:
                    </TextBlock>
                    <TextBlock x:Name="RecommendedVersionText"
                               FontSize="11"
                               FontFamily="Consolas"
                               Foreground="#107C10"
                               Margin="4,0,0,0"/>
                </StackPanel>
            </StackPanel>

            <!-- SAST/ASCA Remediation Advice -->
            <StackPanel x:Name="RemediationPanel" Visibility="Collapsed" Margin="0,0,0,8">
                <TextBlock FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#DCDCDC"
                           Margin="0,0,0,4">
                    Remediation:
                </TextBlock>
                <TextBlock x:Name="RemediationText"
                           FontSize="11"
                           TextWrapping="Wrap"
                           Foreground="#DCDCDC"/>
            </StackPanel>

            <!-- KICS/IaC Expected vs Actual Values -->
            <StackPanel x:Name="IacValuesPanel" Visibility="Collapsed" Margin="0,0,0,8">
                <TextBlock FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#DCDCDC"
                           Margin="0,0,0,4">
                    Expected Value:
                </TextBlock>
                <TextBlock x:Name="ExpectedValueText"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#107C10"
                           Margin="0,0,0,8"/>

                <TextBlock FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#DCDCDC"
                           Margin="0,0,0,4">
                    Actual Value:
                </TextBlock>
                <TextBlock x:Name="ActualValueText"
                           FontSize="11"
                           FontFamily="Consolas"
                           Foreground="#D32F2F"/>
            </StackPanel>
            
            <!-- Location Information -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock x:Name="LocationTextBlock" FontSize="11"
                           Foreground="#DCDCDC">
                    <Run Text="Location: "/>
                    <Run x:Name="LocationText" FontFamily="Consolas"/>
                </TextBlock>
            </StackPanel>
            
            <!-- Separator -->
            <Border x:Name="SeparatorLine2" Height="1" 
                    Background="#3F3F46"
                    Margin="0,0,0,8"/>
            
            <!-- JetBrains-style action links: Fix with CxOne Assist, View details, Ignore this, Ignore all of this type -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,4">
                <TextBlock>
                    <Hyperlink x:Name="FixWithCxOneAssistLink"
                               TextDecorations="None"
                               Foreground="#3794FF">
                        <Run Text="Fix with Checkmarx One Assist"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock Margin="10,0,0,0">
                    <Hyperlink x:Name="ViewDetailsLink"
                               TextDecorations="None"
                               Foreground="#3794FF">
                        <Run Text="View details"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock Margin="10,0,0,0">
                    <Hyperlink x:Name="IgnoreThisLink"
                               TextDecorations="None"
                               Foreground="#3794FF">
                        <Run Text="Ignore this vulnerability"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock x:Name="IgnoreAllOfThisTypeBlock" Margin="10,0,0,0" Visibility="Collapsed">
                    <Hyperlink x:Name="IgnoreAllOfThisTypeLink"
                               TextDecorations="None"
                               Foreground="#3794FF">
                        <Run Text="Ignore all of this type"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
            
            <!-- Secondary links (Navigate to Code, Learn More, Apply Fix) -->
        <StackPanel x:Name="SecondaryLinksPanel" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,10">
            <TextBlock x:Name="LearnMoreLinkBlock" Margin="10,0,0,0" Visibility="Collapsed">
                    <Hyperlink x:Name="LearnMoreLink"
                               TextDecorations="None"
                               Foreground="#3794FF">
                        <Run Text="Learn More"/>
                    </Hyperlink>
                </TextBlock>
                <TextBlock x:Name="ApplyFixLinkBlock" Margin="10,0,0,0" Visibility="Collapsed">
                    <Hyperlink x:Name="ApplyFixLink"
                               TextDecorations="None"
                               Foreground="#3794FF">
                        <Run Text="Apply Fix"/>
                    </Hyperlink>
                </TextBlock>
            </StackPanel>
        </StackPanel>
</Border>

